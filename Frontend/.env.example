# URL base de la API del backend (HAKU Courier, NestJS). Incluye prefijo y version.
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Timeout de las peticiones HTTP, en milisegundos.
VITE_API_TIMEOUT_MS=15000

# Nombre visible de la aplicacion (usado en el layout/titulo).
VITE_APP_NAME=HAKU Courier
