# Entorno de ejecucion: development | production | test
NODE_ENV=development

# HTTP
PORT=3000
API_PREFIX=api
API_VERSION=1
# Obligatoria. Lista de origenes permitidos separados por coma (sin
# espacios extra necesarios, se recortan automaticamente). Ejemplo con
# varios origenes para produccion: CORS_ORIGIN=https://app.hakucourier.com,https://admin.hakucourier.com
CORS_ORIGIN=http://localhost:5173

# Base de datos MySQL (contenedor Docker existente)
DATABASE_URL="mysql://usuario:password@localhost:3306/nombre_bd"
