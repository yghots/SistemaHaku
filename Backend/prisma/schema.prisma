generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum RolUsuario {
  administrador
  motorizado
}

// Flujo principal (doc 2.3): pendiente -> asignado -> recogido -> en_ruta -> entregado
// Estados alternativos: cancelado, reprogramado, devuelto, rechazado, cliente_ausente
enum EstadoPedido {
  pendiente
  asignado
  recogido
  en_ruta
  entregado
  cancelado
  reprogramado
  devuelto
  rechazado
  cliente_ausente
}

enum TipoEventoHistorial {
  cambio_estado
  reasignacion
}

// Fase XX (Solicitudes de Pedido): canal de ingreso previo al Pedido,
// pensado para integraciones externas (WhatsApp, formulario web, API) que
// todavia no deben crear un Pedido directamente. 'pendiente' es el unico
// estado desde el que se puede aprobar/rechazar (transicion final, sin
// reversa) — mismo criterio de estado terminal ya usado en EstadoPedido.
enum EstadoSolicitudPedido {
  pendiente
  aprobada
  rechazada
}

enum TipoFoto {
  recojo
  entrega
}

// "Accidente, averia, dano al producto, etc." (doc 4.1) - conjunto cerrado
// con valor de escape 'otro' para cubrir el "etc." de la documentacion.
enum TipoIncidente {
  accidente
  averia
  dano_producto
  otro
}

// Fase 19 (Centro de Importaciones): entidades que soportan importacion
// masiva. Infraestructura preparada para futuras entidades — agregar un
// valor aqui cuando se sume una nueva.
enum EntidadImportacion {
  cliente
  tienda
  motorizado
}

enum FormatoImportacion {
  xlsx
  json
  xml
}

// 'completado' = 100% de las filas importadas sin duplicados ni errores;
// 'parcial' = el resto (incluye el caso de 0 filas importadas). El
// historial solo se persiste una vez el archivo se proceso por completo
// (nunca en un estado intermedio) — ver ImportacionesService.
enum EstadoImportacion {
  completado
  parcial
}

enum EstadoFilaImportacion {
  duplicado
  invalido
}

// Fase 20 (Modulo de Pagos): conjunto cerrado de metodos de pago
// soportados — agregar uno nuevo en el futuro es una migracion de bajo
// riesgo (agregar un valor al enum), nunca un string libre.
enum MetodoPago {
  efectivo
  yape
  plin
  transferencia
  tarjeta
}

// ---------------------------------------------------------------------------
// Modelos
// ---------------------------------------------------------------------------

model Usuario {
  id           BigInt     @id @default(autoincrement())
  nombres      String     @db.VarChar(100)
  apellidos    String     @db.VarChar(100)
  usuario      String     @unique @db.VarChar(50)
  correo       String     @unique @db.VarChar(150)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  rol          RolUsuario
  activo       Boolean    @default(true)
  deletedAt    DateTime?  @map("deleted_at")

  perfilMotorizado PerfilMotorizado?
  pedidosCreados   Pedido[]               @relation("PedidosCreadosPorUsuario")
  eventosHistorial HistorialPedido[]      @relation("EventosRegistradosPorUsuario")
  importaciones    ImportacionHistorial[]
  pagosRegistrados Pago[]                 @relation("PagosRegistradosPorUsuario")

  @@map("usuarios")
}

model Tienda {
  id        BigInt    @id @default(autoincrement())
  nombre    String    @db.VarChar(150)
  // @unique (Fase 28, correccion C2 de la auditoria): antes solo se
  // verificaba en el servicio (verificar-luego-escribir, sin atomicidad),
  // la misma clase de condicion de carrera que ya se habia corregido para
  // Pedido en la Fase 15. MySQL permite multiples NULL en un indice unico,
  // asi que el campo sigue siendo opcional sin restriccion para quien no
  // lo provee. Deliberadamente solo el RUC — `nombre` no se toca.
  ruc       String?   @unique @db.VarChar(20)
  activo    Boolean   @default(true)
  deletedAt DateTime? @map("deleted_at")

  sucursales Sucursal[]

  @@map("tiendas")
}

model Sucursal {
  id          BigInt    @id @default(autoincrement())
  tiendaId    BigInt    @map("tienda_id")
  nombre      String    @db.VarChar(150)
  direccion   String    @db.VarChar(255)
  referencia  String?   @db.VarChar(255)
  telefono    String    @db.VarChar(20)
  esPrincipal Boolean   @default(false) @map("es_principal")
  deletedAt   DateTime? @map("deleted_at")

  tienda      Tienda            @relation(fields: [tiendaId], references: [id], onDelete: Restrict)
  pedidos     Pedido[]
  solicitudes SolicitudPedido[]

  @@map("sucursales")
}

model Cliente {
  id                 BigInt    @id @default(autoincrement())
  nombreCompleto     String    @map("nombre_completo") @db.VarChar(150)
  telefono           String    @db.VarChar(20)
  direccion          String    @db.VarChar(255)
  // @unique (Fase 19): MySQL permite multiples NULL en un indice unico, asi
  // que el campo sigue siendo opcional sin restriccion para quien no lo
  // provee — necesario para que la importacion masiva de Clientes pueda
  // detectar duplicados por este campo (ver DEVELOPMENT_PROGRESS.md Fase 17).
  documentoIdentidad String?   @unique @map("documento_identidad") @db.VarChar(20)
  deletedAt          DateTime? @map("deleted_at")

  pedidos     Pedido[]
  solicitudes SolicitudPedido[]

  @@map("clientes")
}

// Fase XX (Solicitudes de Pedido): canal de ingreso previo al Pedido, para
// integraciones externas (WhatsApp, formulario web, API) que registran una
// solicitud sin crear directamente un Pedido. Un administrador la aprueba
// (crea/actualiza el Cliente por telefono y crea el Pedido con el flujo ya
// existente) o la rechaza (con motivo). `clienteId`/`pedidoId` quedan nulos
// hasta la aprobacion — son el rastro de que efecto tuvo la solicitud, nunca
// se escriben en la creacion publica. Sin `creadoPorId`: el origen es
// publico/no autenticado, a diferencia de Pedido.creadoPorId.
model SolicitudPedido {
  id                  BigInt                @id @default(autoincrement())
  sucursalId          BigInt                @map("sucursal_id")
  nombreCompleto      String                @map("nombre_completo") @db.VarChar(150)
  telefono            String                @db.VarChar(20)
  direccionEntrega    String                @map("direccion_entrega") @db.VarChar(255)
  descripcionProducto String?               @map("descripcion_producto") @db.VarChar(255)
  valorProducto       Decimal?              @map("valor_producto") @db.Decimal(10, 2)
  costoEnvio          Decimal?              @map("costo_envio") @db.Decimal(10, 2)
  observaciones       String?               @db.VarChar(500)
  estado              EstadoSolicitudPedido @default(pendiente)
  motivoRechazo       String?               @map("motivo_rechazo") @db.VarChar(255)
  clienteId           BigInt?               @map("cliente_id")
  pedidoId            BigInt?               @unique @map("pedido_id")
  creadoEn            DateTime              @default(now()) @map("creado_en")
  revisadoEn          DateTime?             @map("revisado_en")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  cliente  Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  pedido   Pedido?  @relation(fields: [pedidoId], references: [id], onDelete: SetNull)

  @@index([estado])
  @@index([creadoEn])
  @@index([sucursalId])
  @@map("solicitudes_pedido")
}

model PerfilMotorizado {
  id        BigInt @id @default(autoincrement())
  usuarioId BigInt @unique @map("usuario_id")
  // @unique (Fase 19): necesario para que la importacion masiva de
  // Motorizados pueda detectar placas duplicadas (ver DEVELOPMENT_PROGRESS.md
  // Fase 17).
  placa     String @unique @db.VarChar(15)
  // `estado` (EstadoMotorizado: disponible/ocupado/inactivo) eliminado en
  // la Fase 33 (Parte 4 del rediseno de ciclo de vida): confirmado que
  // nunca participo en ninguna regla de negocio de flujo-pedido (hallazgo
  // A3 de la auditoria, Fase 27/29) — el estado operativo real de un
  // motorizado ahora se deriva unicamente de `Usuario.activo`.

  usuario          Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  pedidosActuales  Pedido[]          @relation("MotorizadoActualDelPedido")
  fotos            FotoEntrega[]
  incidentes       Incidente[]
  eventosHistorial HistorialPedido[] @relation("ReasignacionesDelMotorizado")

  @@map("perfiles_motorizados")
}

model Pedido {
  id                  BigInt       @id @default(autoincrement())
  codigoPedido        String       @unique @map("codigo_pedido") @db.VarChar(30)
  sucursalId          BigInt       @map("sucursal_id")
  clienteId           BigInt       @map("cliente_id")
  motorizadoActualId  BigInt?      @map("motorizado_actual_id")
  creadoPorId         BigInt       @map("creado_por_id")
  direccionEntrega    String       @map("direccion_entrega") @db.VarChar(255)
  telefonoContacto    String?      @map("telefono_contacto") @db.VarChar(20)
  descripcionProducto String?      @map("descripcion_producto") @db.VarChar(255)
  valorProducto       Decimal?     @map("valor_producto") @db.Decimal(10, 2)
  costoEnvio          Decimal?     @map("costo_envio") @db.Decimal(10, 2)
  estado              EstadoPedido @default(pendiente)
  observaciones       String?      @db.VarChar(500)
  creadoEn            DateTime     @default(now()) @map("creado_en")

  sucursal         Sucursal          @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  cliente          Cliente           @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  motorizadoActual PerfilMotorizado? @relation("MotorizadoActualDelPedido", fields: [motorizadoActualId], references: [id], onDelete: SetNull)
  creadoPor        Usuario           @relation("PedidosCreadosPorUsuario", fields: [creadoPorId], references: [id], onDelete: Restrict)

  fotos           FotoEntrega[]
  historial       HistorialPedido[]
  incidentes      Incidente[]
  pagos           Pago[]
  solicitudPedido SolicitudPedido?

  @@index([estado])
  @@index([creadoEn])
  @@map("pedidos")
}

model HistorialPedido {
  id           BigInt              @id @default(autoincrement())
  pedidoId     BigInt              @map("pedido_id")
  tipoEvento   TipoEventoHistorial @map("tipo_evento")
  estado       EstadoPedido?
  motorizadoId BigInt?             @map("motorizado_id")
  usuarioId    BigInt              @map("usuario_id")
  createdAt    DateTime            @default(now()) @map("created_at")

  pedido     Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  motorizado PerfilMotorizado? @relation("ReasignacionesDelMotorizado", fields: [motorizadoId], references: [id], onDelete: SetNull)
  usuario    Usuario           @relation("EventosRegistradosPorUsuario", fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId, createdAt])
  @@map("historial_pedido")
}

// Fase 22: las fotografias se almacenan directamente en MySQL (LONGBLOB),
// nunca como URL/archivo externo — decision arquitectonica definitiva del
// proyecto. `imagen` es el binario crudo; `mimeType` siempre 'image/webp'
// en la practica (unico formato aceptado por la validacion de la capa de
// aplicacion, ver `modules/fotos-entrega/foto-entrega.validator.ts`), el
// default a nivel de columna es solo una red de seguridad del esquema.
model FotoEntrega {
  id           BigInt   @id @default(autoincrement())
  pedidoId     BigInt   @map("pedido_id")
  motorizadoId BigInt   @map("motorizado_id")
  tipo         TipoFoto
  imagen       Bytes    @db.LongBlob
  mimeType     String   @default("image/webp") @map("mime_type") @db.VarChar(50)
  esPrincipal  Boolean  @default(false) @map("es_principal")

  pedido     Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  motorizado PerfilMotorizado @relation(fields: [motorizadoId], references: [id], onDelete: Restrict)

  @@index([pedidoId, tipo])
  @@map("fotos_entrega")
}

model Incidente {
  id           BigInt        @id @default(autoincrement())
  pedidoId     BigInt?       @map("pedido_id")
  motorizadoId BigInt        @map("motorizado_id")
  tipo         TipoIncidente
  resuelto     Boolean       @default(false)

  pedido     Pedido?          @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  motorizado PerfilMotorizado @relation(fields: [motorizadoId], references: [id], onDelete: Restrict)

  @@index([motorizadoId, resuelto])
  @@map("incidentes")
}

// Fase 19 (Centro de Importaciones): un registro por archivo procesado
// hasta el final (exito total o parcial) — nunca en un estado intermedio.
model ImportacionHistorial {
  id                    BigInt             @id @default(autoincrement())
  entidad               EntidadImportacion
  archivoNombre         String             @map("archivo_nombre") @db.VarChar(255)
  formato               FormatoImportacion
  usuarioId             BigInt             @map("usuario_id")
  totalEncontrados      Int                @map("total_encontrados")
  importados            Int
  duplicados            Int
  errores               Int
  tiempoProcesamientoMs Int                @map("tiempo_procesamiento_ms")
  estado                EstadoImportacion
  creadoEn              DateTime           @default(now()) @map("creado_en")

  usuario  Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  detalles ImportacionDetalle[]

  @@index([entidad, creadoEn])
  @@map("importacion_historial")
}

// Solo filas que NO se importaron (duplicado/invalido) — las importadas se
// cuentan en ImportacionHistorial.importados, sin necesidad de una fila por
// registro exitoso. Es la misma fuente para el detalle del historial y para
// regenerar el reporte de errores en xlsx (reutiliza common/exports).
model ImportacionDetalle {
  id          BigInt                @id @default(autoincrement())
  historialId BigInt                @map("historial_id")
  fila        Int
  estado      EstadoFilaImportacion
  motivo      String                @db.VarChar(255)
  campo       String?               @db.VarChar(100)
  valor       String?               @db.VarChar(255)

  historial ImportacionHistorial @relation(fields: [historialId], references: [id], onDelete: Cascade)

  @@index([historialId])
  @@map("importacion_detalle")
}

// Fase 20 (Modulo de Pagos): un pedido puede tener 0, 1 o muchos pagos
// (parciales y/o mixtos, cualquier combinacion de metodos). Cada pago es un
// registro independiente e inmutable — no hay UPDATE ni DELETE sobre esta
// tabla (ver PagosService: solo `crear`/`buscarPorPedido`). El total del
// pedido, el total pagado, el saldo pendiente y el estado de pago nunca se
// almacenan: se calculan siempre a partir de estos registros.
model Pago {
  id            BigInt     @id @default(autoincrement())
  pedidoId      BigInt     @map("pedido_id")
  metodoPago    MetodoPago @map("metodo_pago")
  monto         Decimal    @db.Decimal(10, 2)
  // Solo aplican para metodoPago = efectivo; NULL para el resto de metodos.
  montoRecibido Decimal?   @map("monto_recibido") @db.Decimal(10, 2)
  vuelto        Decimal?   @db.Decimal(10, 2)
  observacion   String?    @db.VarChar(255)
  creadoPorId   BigInt     @map("creado_por_id")
  creadoEn      DateTime   @default(now()) @map("creado_en")

  pedido    Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  creadoPor Usuario @relation("PagosRegistradosPorUsuario", fields: [creadoPorId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@map("pagos")
}
